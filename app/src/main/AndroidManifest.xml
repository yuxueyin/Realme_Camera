<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:icon="@drawable/ic_lumo_camera"
        android:roundIcon="@drawable/ic_lumo_camera"
        android:label="@string/app_name"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:theme="@style/Theme.Lumo.Native">

        <activity
            android:name="com.camera.VendorTag.ui.VendorTagSettingsActivity"
            android:exported="true"
            android:theme="@style/Theme.Lumo.Native"
            android:label="@string/app_name">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="com.camera.VendorTag.ui.VendorTagSettingsProvider"
            android:authorities="com.camera.lumo.vendortag"
            android:exported="true" />

    </application>

</manifest>