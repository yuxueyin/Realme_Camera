<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/lumo_input_bg" />
            <corners android:radius="18dp" />
            <stroke
                android:width="2dp"
                android:color="@color/lumo_primary" />
            <padding
                android:left="14dp"
                android:top="10dp"
                android:right="14dp"
                android:bottom="10dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/lumo_input_bg" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/lumo_outline" />
            <padding
                android:left="14dp"
                android:top="10dp"
                android:right="14dp"
                android:bottom="10dp" />
        </shape>
    </item>

</selector>